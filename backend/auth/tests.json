{
  "tests": [
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/login",
      "body": {"email": "wrong@mail.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify without token",
      "method": "GET",
      "path": "/verify",
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}
