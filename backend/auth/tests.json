{
  "tests": [
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "wrong@mail.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "token": ""},
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    }
  ]
}
